# ============================================================================
# Rift League Manager — Environment
# ============================================================================
# The app runs fully in MOCK MODE with zero configuration. Mock mode persists
# data to the browser (localStorage) and syncs live across tabs via the
# BroadcastChannel API — so simulation, trades, standings and realtime all work
# out of the box with `npm run dev`.
#
# Provide the Supabase variables below ONLY if you want a shared, server-backed
# database with multi-user Auth/Postgres/Storage/Realtime. When these are set,
# the app switches from mock mode to Supabase automatically.
# ----------------------------------------------------------------------------

# Public Supabase project URL (e.g. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only. NEVER expose to the client.
# Used by the import services and admin tasks that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Force mock mode even if Supabase vars are present (handy for local demos).
# Set to "true" to always use the in-browser mock store.
NEXT_PUBLIC_FORCE_MOCK=

# Optional: a Riot / external data API base for the import adapters.
# The bundled adapters work without this (they use public wiki/CDN endpoints
# and gracefully fall back to seeded data when offline).
LOL_ESPORTS_API_BASE=
