# ===========================================================================
# Dependencies
# ===========================================================================
/node_modules
/.pnp
.pnp.js
.yarn/*

# ===========================================================================
# Next.js / build output
# ===========================================================================
/.next/
/out/
/build
/dist
next-env.d.ts
*.tsbuildinfo

# ===========================================================================
# Environment & secrets  (keep .env.example tracked)
# ===========================================================================
.env
.env.*
!.env.example

# ===========================================================================
# Supabase (local CLI artifacts)
# ===========================================================================
/supabase/.branches
/supabase/.temp
/supabase/.env

# ===========================================================================
# Logs & temp
# ===========================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
*.tmp

# ===========================================================================
# Private imported team logos (Liquipedia importer output)
# ---------------------------------------------------------------------------
# Real team logos fetched by scripts/import-liquipedia-logos.ts are official,
# trademarked artwork imported for PRIVATE prototype use only. They are kept
# local/untracked by default and are NOT committed. The repo ships only the
# IP-safe placeholder badges under public/assets/teams/lol/. To intentionally
# commit a real logo you own the rights to, force-add it:
#   git add -f public/assets/teams/lol/real/<file>
# ===========================================================================
/public/assets/teams/lol/real/

# ===========================================================================
# Deploy / tooling caches
# ===========================================================================
/coverage
.vercel
.turbo

# ===========================================================================
# Editor & OS
# ===========================================================================
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ===========================================================================
# Local tooling config (machine-specific)
# ===========================================================================
.claude/
