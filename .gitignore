# ===========================================================================
# Dependencies
# ===========================================================================
/node_modules
/.pnp
.pnp.js
.yarn/*

# ===========================================================================
# Next.js / build output
# ===========================================================================
/.next/
/out/
/build
/dist
next-env.d.ts
*.tsbuildinfo

# ===========================================================================
# Environment & secrets  (keep .env.example tracked)
# ===========================================================================
.env
.env.*
!.env.example

# ===========================================================================
# Supabase (local CLI artifacts)
# ===========================================================================
/supabase/.branches
/supabase/.temp
/supabase/.env

# ===========================================================================
# Logs & temp
# ===========================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
*.tmp

# ===========================================================================
# Deploy / tooling caches
# ===========================================================================
/coverage
.vercel
.turbo

# ===========================================================================
# Editor & OS
# ===========================================================================
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ===========================================================================
# Local tooling config (machine-specific)
# ===========================================================================
.claude/
