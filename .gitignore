# ===========================================================================
# Dependencies
# ===========================================================================
/node_modules
/.pnp
.pnp.js
.yarn/*

# ===========================================================================
# Next.js / build output
# ===========================================================================
/.next/
/out/
/build
/dist
next-env.d.ts
*.tsbuildinfo

# ===========================================================================
# Environment & secrets  (keep .env.example tracked)
# ===========================================================================
.env
.env.*
!.env.example

# ===========================================================================
# Supabase (local CLI artifacts)
# ===========================================================================
/supabase/.branches
/supabase/.temp
/supabase/.env

# ===========================================================================
# Logs & temp
# ===========================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
*.tmp

# ===========================================================================
# Imported team logos (Liquipedia importer output)
# ---------------------------------------------------------------------------
# Real team logos fetched by scripts/import-liquipedia-logos.ts are official,
# trademarked artwork. For this PRIVATE prototype they are committed
# intentionally so the deployed app shows real logos instead of placeholders;
# provenance/license is tracked in docs/logo-attribution.md (marked "review
# required" — no ownership is claimed, not cleared for public redistribution).
# The folder below is therefore NOT ignored. Only the importer's API response
# cache is ignored (see .cache/ above), never the image files themselves.
# ===========================================================================

# ===========================================================================
# Deploy / tooling caches
# ===========================================================================
/coverage
.vercel
.turbo

# ===========================================================================
# Editor & OS
# ===========================================================================
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ===========================================================================
# Local tooling config (machine-specific)
# ===========================================================================
.claude/
